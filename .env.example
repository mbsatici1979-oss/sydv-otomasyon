# Local server port
PORT=8091

# Data backend. Use "supabase" on Vercel when DATABASE_URL is configured.
DATA_BACKEND=supabase

# Temporary login bypass. Set to 0 to enable username/password login again.
AUTH_DISABLED=1

# Supabase PostgreSQL connection string. Do not commit a real value.
DATABASE_URL=postgresql://user:password@host:5432/database

# Temporary password for the first admin user on a fresh installation.
# Change this before first run and do not commit a real .env file.
INITIAL_ADMIN_PASSWORD=change-this-before-first-run
